{
  "name": "pluto-server",
  "version": "1.0.0",
  "private": true,
  "description": "Pluto server - Express + TypeScript + SQLite",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "generate:vapid": "web-push generate-vapid-keys"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pluto-poc": "file:..",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "@types/web-push": "^3.6.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
