# Copy to `.env` for local dev, or set these in the Railway dashboard.

# Generate with: npm run generate:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI for push services (mailto: or https:)
VAPID_SUBJECT=mailto:you@example.com

# Minutes before the 5-hour garden window closes to send a reminder push.
# Lower this (e.g. 1) to demo the reminder quickly.
REMINDER_LEAD_MINUTES=15

# SQLite path. Optional. On Railway, just attach a Volume — the app auto-detects
# RAILWAY_VOLUME_MOUNT_PATH and stores the DB there. Set this only to override
# the location explicitly, e.g. DATABASE_PATH=/data/pluto.db
# DATABASE_PATH=

# Port (Railway injects this automatically).
# PORT=3001
